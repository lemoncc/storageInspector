{
  "manifest_version": 3,
  "name": "应用存储读/写",
  "version": "1.7.4",
  "description": "读取/写入当前页面 localStorage、sessionStorage、cookie（含 HttpOnly）指定 key 的值",
  "permissions": ["activeTab", "scripting", "storage", "cookies"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "应用存储读/写",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
